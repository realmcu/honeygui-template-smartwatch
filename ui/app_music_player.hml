<?xml version="1.0" encoding="UTF-8"?>
<hml>
    <meta>
        <project name="SmartWatchTemplate" description="HoneyGUI Project" version="1.0.0" resolution="410X502" minSdk="API 2: HoneyGUI V1.1.0" pixelMode="ARGB8888" />
        <author name="HoneyGUI Design" />
    </meta>
    <view>
        <hg_view id="app_music_playerPlayerView" x="0" y="0" width="410" height="502" backgroundColor="#292826" borderRadius="0" padding="0" overflow="auto"  zIndex="0">
            <events>
                <event type="onKeyShortPress" keyName="Home">
                    <action type="switchView" target="SmartWatchTemplateMainView" switchOutStyle="SWITCH_OUT_ANIMATION_FADE" switchInStyle="SWITCH_IN_ANIMATION_FADE" />
                </event>
                <event type="onKeyShortPress" keyName="Menu">
                    <action type="switchView" target="app_menu_view" switchOutStyle="SWITCH_OUT_ANIMATION_FADE" switchInStyle="SWITCH_IN_ANIMATION_FADE" />
                </event>
            </events>
            <hg_image id="player_bg" x="0" y="0" width="410" height="502" src="assets/app_music_player/music_player_bg.png" timers="[{&quot;id&quot;:&quot;timer_0&quot;,&quot;name&quot;:&quot;player_init&quot;,&quot;enabled&quot;:true,&quot;interval&quot;:10,&quot;reload&quot;:false,&quot;mode&quot;:&quot;custom&quot;,&quot;callback&quot;:&quot;player_view_init_cb&quot;,&quot;duration&quot;:0,&quot;stopOnComplete&quot;:true,&quot;delayStart&quot;:0,&quot;actions&quot;:[],&quot;segments&quot;:[]}]" zIndex="0" />
            <hg_image id="player_back_btn" x="32" y="28" width="32" height="32" src="assets/app_music_player/back_icon.png" zIndex="1">
                <events>
                    <event type="onClick">
                        <action type="switchView" target="app_menu_view" switchOutStyle="SWITCH_OUT_ANIMATION_FADE" switchInStyle="SWITCH_IN_ANIMATION_FADE" />
                    </event>
                </events>
            </hg_image>
            <hg_label id="song_title_label" x="55" y="68" width="300" height="28" hAlign="CENTER" vAlign="MID" color="#f2f2f2" letterSpacing="0" lineSpacing="0" wordWrap="false" wordBreak="false" text="Let Me Know" fontFile="/font/Inter_24pt_Regular.ttf" fontSize="22" characterSets="[{&quot;type&quot;:&quot;range&quot;,&quot;value&quot;:&quot;0x20-0x7E&quot;}]" zIndex="1" />
            <hg_label id="artist_label" x="55" y="100" width="300" height="18" hAlign="CENTER" vAlign="MID" color="#666666" letterSpacing="0" lineSpacing="0" wordWrap="false" wordBreak="false" text="No Wyld" fontFile="/font/Inter_24pt_Regular.ttf" fontSize="14" characterSets="[{&quot;type&quot;:&quot;range&quot;,&quot;value&quot;:&quot;0x20-0x7E&quot;}]" zIndex="1" />
            <hg_arc id="progress_ring_bg" x="100" y="122" width="210" height="210" radius="96" startAngle="0" endAngle="360" strokeWidth="6" color="#F9D342" opacity="38" zIndex="1" />
            <hg_arc id="progress_ring" x="100" y="122" width="210" height="210" radius="96" startAngle="-90" endAngle="-90" strokeWidth="6" color="#F9D342" opacity="255" timers="[{&quot;id&quot;:&quot;timer_0&quot;,&quot;name&quot;:&quot;progress_anim&quot;,&quot;enabled&quot;:true,&quot;interval&quot;:28,&quot;reload&quot;:true,&quot;mode&quot;:&quot;custom&quot;,&quot;callback&quot;:&quot;music_progress_timer_cb&quot;,&quot;duration&quot;:0,&quot;stopOnComplete&quot;:false,&quot;delayStart&quot;:0,&quot;actions&quot;:[],&quot;segments&quot;:[]}]" zIndex="2" />
            <hg_image id="album_cover" x="115" y="137" width="180" height="180" borderRadius="90" src="assets/app_music_player/cover_1.png" zIndex="3" />
            <hg_image id="skip_back_btn" x="97" y="348" width="48" height="48" src="assets/app_music_player/skip_back_btn.png" zIndex="1">
                <events>
                    <event type="onClick">
                        <action type="callFunction" functionName="music_prev" />
                    </event>
                </events>
            </hg_image>
            <hg_image id="play_pause_btn" x="177" y="342" width="56" height="56" src="assets/app_music_player/play_btn.png" zIndex="1">
                <events>
                    <event type="onClick">
                        <action type="callFunction" functionName="music_toggle_play" />
                    </event>
                </events>
            </hg_image>
            <hg_image id="skip_forward_btn" x="265" y="348" width="48" height="48" src="assets/app_music_player/skip_forward_btn.png" zIndex="1">
                <events>
                    <event type="onClick">
                        <action type="callFunction" functionName="music_next" />
                    </event>
                </events>
            </hg_image>
            <hg_image id="volume_btn" x="60" y="410" width="52" height="52" src="assets/app_music_player/volume_btn.png" zIndex="1">
                <events>
                    <event type="onClick">
                        <action type="callFunction" functionName="music_show_volume" />
                    </event>
                </events>
            </hg_image>
            <hg_image id="list_btn" x="298" y="410" width="52" height="52" src="assets/app_music_player/list_btn.png" zIndex="1">
