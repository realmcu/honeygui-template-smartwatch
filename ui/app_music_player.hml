                <hg_image id="vol_close_btn" x="177" y="345" width="56" height="56" src="assets/app_music_player/close_btn.png" zIndex="1">
                    <events>
                        <event type="onClick">
                            <action type="callFunction" functionName="music_close_volume" />
                        </event>
                    </events>
                </hg_image>
