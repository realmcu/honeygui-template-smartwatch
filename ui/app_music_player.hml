                <hg_image id="vol_plus_btn" x="269" y="237" width="72" height="72" src="assets/app_music_player/plus_btn.png" zIndex="1">
                    <events>
                        <event type="onClick">
                            <action type="callFunction" functionName="music_volume_up" />
