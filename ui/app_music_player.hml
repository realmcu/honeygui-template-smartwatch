                <hg_rect id="volume_overlay_bg" x="0" y="0" width="410" height="502" borderRadius="90" fillColor="#141311" opacity="234" zIndex="0" />
                <hg_label id="volume_title_label" x="155" y="175" width="100" height="24" hAlign="CENTER" vAlign="MID" color="#f2f2f2" letterSpacing="0" lineSpacing="0" wordWrap="false" wordBreak="false" text="Volume" fontFile="/font/Inter_24pt_Regular.ttf" fontSize="18" zIndex="1" />
                <hg_rect id="volume_bar_bg" x="85" y="211" width="240" height="10" borderRadius="5" fillColor="#262626" opacity="255" zIndex="1" />
                <hg_rect id="volume_bar_fill" x="85" y="211" width="168" height="10" borderRadius="5" fillColor="#F9D342" opacity="255" zIndex="2" />
