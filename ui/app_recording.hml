                <hg_label id="hg_label_1770773126771_k7n4" x="261" y="57" width="119" height="32" hAlign="RIGHT" vAlign="TOP" color="#ec1a45" letterSpacing="0" lineSpacing="0" wordWrap="false" wordBreak="false" text="Recording" fontFile="/font/Inter_24pt_Regular.ttf" fontSize="30" zIndex="0" />
            </hg_window>
        </hg_view>
